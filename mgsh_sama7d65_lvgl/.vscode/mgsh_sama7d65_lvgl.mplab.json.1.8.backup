{
    "version": "1.8",
    "configurations": [
        {
            "name": "default",
            "id": "conf1",
            "device": "SAMA7D65D2G",
            "imagePath": "./out/mgsh_sama7d65_lvgl/default.elf",
            "packs": [
                {
                    "name": "SAMA7D65_DFP",
                    "vendor": "Microchip",
                    "version": "1.11.113"
                },
                {
                    "name": "CMSIS",
                    "vendor": "ARM",
                    "version": "6.3.0"
                }
            ],
            "fileSet": "default",
            "toolchain": "default-XC32"
        }
    ],
    "propertyGroups": [
        {
            "name": "default-XC32",
            "type": "toolchain",
            "provider": "microchip.toolchains:xc32@5.00",
            "properties": {}
        }
    ],
    "fileSets": [
        {
            "name": "default",
            "files": [
                {
                    "include": "**/*",
                    "exclude": "**/(_build|out|cmake|.vscode)/**/*"
                }
            ]
        }
    ]
}
